# Supabase — copy to .env.local and fill in your project values
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Feature flags
# Regulix partner integration. Keep 'false' until the Regulix connection is
# live — when off, all Regulix badges, "Regulix Preferred" jobs, endorsements,
# nudges, status boxes, and Regulix-only filters are hidden. Set to 'true' to
# enable. Requires a redeploy to take effect (build-time flag).
VITE_ENABLE_REGULIX=false
